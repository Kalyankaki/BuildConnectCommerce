# RenovateConnect — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.

# ── App ──────────────────────────────────────────────────────────────────────
# Root domain used for tenant subdomains, e.g. acme.renovateconnect.app
NEXT_PUBLIC_ROOT_DOMAIN=renovateconnect.app
# Base URL for callbacks / absolute links in dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Postgres + RLS) ────────────────────────────────────────────────
# Admin/migration connection: superuser/service role that BYPASSES RLS.
# Used by drizzle-kit (migrations) and (admin) service-role server actions only.
DATABASE_URL=
# Runtime connection: non-superuser role with RLS ENFORCED. Used by withTenant()
# for all tenant-scoped queries. On Supabase this maps to the anon/authenticated role.
APP_DATABASE_URL=
# Local-only: connection to the default `postgres` db, used by `npm run db:setup`
# to create the dev database + app role. Not needed on Supabase.
ADMIN_BOOTSTRAP_URL=

# ── Supabase (used from M2+ for Auth + Storage; Postgres URLs above) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used ONLY in (admin) server actions. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Connect Standard) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Connect platform settings
STRIPE_CONNECT_CLIENT_ID=
# Platform take rate in basis points (e.g. 500 = 5%); can also live in DB config.
PLATFORM_TAKE_RATE_BPS=500
# Deposit percentage charged at booking (e.g. 50 = 50%); per-tenant override in DB.
DEFAULT_DEPOSIT_PERCENT=50

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── SMS (Twilio, optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Custom domains (Vercel API) ──────────────────────────────────────────────
# When set, resellers can connect their own domain: it's attached to the Vercel
# project and verified automatically. Token: Vercel → Account Settings → Tokens.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
